# Copy to .env and fill with values from your Supabase project settings.
# Do not commit .env.

# Public site URL (no trailing slash). Used for Open Graph / Twitter card images — must match your deployed origin.
# Example: https://appraisal.vgg.app or https://three60appraisal.onrender.com
VITE_SITE_URL=

VITE_SUPABASE_PROJECT_ID=
# Use either publishable (below) or the standard Supabase name:
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=

# Optional: URL to the admin dashboard Excel export (default: /data/VGG_360_Reorganized.xlsx)
# Use a path under public/ locally, or a full URL to hosted storage.
VITE_APPRAISAL_DATA_URL=

# Optional: legacy /admin login (client-side only — prefer employee admin in production)
# Leave unset to disable legacy admin entirely.
VITE_LEGACY_ADMIN_EMAIL=
VITE_LEGACY_ADMIN_PASSWORD=
VITE_LEGACY_ADMIN_NAME=
